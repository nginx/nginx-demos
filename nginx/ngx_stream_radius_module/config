ngx_addon_name=ngx_stream_radius_module

if test -n "$ngx_module_link"; then
    # NGINX 1.9.11+ dynamic module support
    ngx_module_type=STREAM
    ngx_module_name=ngx_stream_radius_module
    ngx_module_srcs="$ngx_addon_dir/src/ngx_stream_radius_module.c \
                     $ngx_addon_dir/src/ngx_stream_radius_parser.c \
                     $ngx_addon_dir/src/ngx_stream_radius_dict.c \
                     $ngx_addon_dir/src/ngx_stream_radius_vars.c"
    ngx_module_incs="$ngx_addon_dir/src"
    ngx_module_deps=""
    ngx_module_libs=""

    . auto/module
else
    # Legacy static module build
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS \
                    $ngx_addon_dir/src/ngx_stream_radius_module.c \
                    $ngx_addon_dir/src/ngx_stream_radius_parser.c \
                    $ngx_addon_dir/src/ngx_stream_radius_dict.c \
                    $ngx_addon_dir/src/ngx_stream_radius_vars.c"

    NGX_ADDON_DEPS="$NGX_ADDON_DEPS \
                    $ngx_addon_dir/src/ngx_stream_radius_module.h \
                    $ngx_addon_dir/src/ngx_stream_radius_parser.h \
                    $ngx_addon_dir/src/ngx_stream_radius_dict.h \
                    $ngx_addon_dir/src/ngx_stream_radius_vars.h"
fi
